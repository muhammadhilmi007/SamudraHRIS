<!-- offboarding.ejs -->
<!-- Modal for Offboarding Karyawan -->
<div class="modal fade" id="offboardingModal" tabindex="-1" aria-labelledby="offboardingModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-danger">
                <h5 class="modal-title text-white" id="offboardingModalLabel"><i class="ti ti-user-x"></i> Offboarding Karyawan &mdash; <%= employee.full_name %></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                
                <!-- Stepper Progress -->
                <div class="row text-center mb-4">
                    <div class="col-4 position-relative">
                        <div class="d-inline-flex align-items-center justify-content-center bg-danger text-white rounded-circle fw-bold" style="width: 40px; height: 40px; border: 3px solid #f8aba6;" id="step1-indicator">1</div>
                        <p class="mt-2 fw-semibold text-danger" id="step1-text">Inisiasi</p>
                        <div class="position-absolute border-top border-2 border-danger" style="top: 20px; left: 50%; width: 100%; z-index: -1;"></div>
                    </div>
                    <div class="col-4 position-relative">
                        <div class="d-inline-flex align-items-center justify-content-center bg-light text-muted rounded-circle fw-bold" style="width: 40px; height: 40px; border: 3px solid #e0e0e0;" id="step2-indicator">2</div>
                        <p class="mt-2 fw-semibold text-muted" id="step2-text">Resolusi Piutang</p>
                        <div class="position-absolute border-top border-2 border-light" style="top: 20px; left: 50%; width: 100%; z-index: -1;"></div>
                    </div>
                    <div class="col-4 position-relative">
                        <div class="d-inline-flex align-items-center justify-content-center bg-light text-muted rounded-circle fw-bold" style="width: 40px; height: 40px; border: 3px solid #e0e0e0;" id="step3-indicator">3</div>
                        <p class="mt-2 fw-semibold text-muted" id="step3-text">Finalisasi</p>
                    </div>
                </div>

                <hr>

                <!-- Step 1: Inisiasi -->
                <div id="offboard-step-1">
                    <form id="formInitOffboard">
                        <div class="alert alert-warning border-0" role="alert">
                            <i class="mdi mdi-alert me-2"></i><strong>Perhatian!</strong> Proses offboarding akan memverifikasi status piutang (kasbon/loan) karyawan. Jika terdapat hutang belum lunas, proses tidak bisa dilanjutkan ke tahap akhir secara otomatis.
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Tanggal Terakhir Bekerja <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="last_working_date" id="offboard_lwd" required>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Tanggal Resign / Nonaktif <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="resign_date" id="offboard_resign_date" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Alasan Offboarding <span class="text-danger">*</span></label>
                            <textarea class="form-control" name="resign_reason" id="offboard_reason" rows="3" placeholder="Contoh: Mengundurkan diri, Habis Kontrak, dsb..." required></textarea>
                        </div>

                        <div class="text-end">
                            <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Batal</button>
                            <button type="submit" class="btn btn-danger" id="btnInitOffboard">Lanjut <i class="ti ti-arrow-right ms-1"></i></button>
                        </div>
                    </form>
                </div>

                <!-- Step 2: Resolusi Piutang (Hidden initally) -->
                <div id="offboard-step-2" class="d-none">
                    <form id="formResolveDebt">
                        <div class="alert alert-danger bg-danger text-white border-0" role="alert">
                            <i class="mdi mdi-alert-circle-outline fs-4 align-middle me-2"></i>
                            <strong>Peringatan!</strong> Karyawan masih memiliki sisa piutang sebesar 
                            <h4 class="text-white mt-2 mb-0" id="offboard_debt_amount">Rp 0</h4>
                        </div>
                        
                        <div class="mb-4">
                            <p class="mb-2 text-muted fw-bold">Pilih Metode Penyelesaian Piutang Sebelum Finalisasi:</p>
                            
                            <div class="form-check form-radio-danger mb-2">
                                <input class="form-check-input" type="radio" name="resolution_method" id="res_salary" value="salary_deduction" checked>
                                <label class="form-check-label" for="res_salary">
                                    Potong dari Gaji Terakhir Secara Penuh (Prorata Payroll)
                                </label>
                            </div>
                            
                            <div class="form-check form-radio-danger">
                                <input class="form-check-input" type="radio" name="resolution_method" id="res_direct" value="direct_payment">
                                <label class="form-check-label" for="res_direct">
                                    Penyelesaian Cash/Transfer terpisah (HR/Finance akan konfirmasi manual)
                                </label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-light" id="btnBackToStep1"><i class="ti ti-arrow-left me-1"></i> Kembali</button>
                            <button type="submit" class="btn btn-danger" id="btnResolveDebt">Konfirmasi Resolusi & Lanjut <i class="ti ti-arrow-right ms-1"></i></button>
                        </div>
                    </form>
                </div>

                <!-- Step 3: Finalisasi (Hidden initially) -->
                <div id="offboard-step-3" class="d-none text-center">
                    <div class="mb-4">
                        <i class="ti ti-check-box text-success" style="font-size: 80px;"></i>
                        <h4 class="mt-3">Semua Validasi Selesai</h4>
                        <p class="text-muted">Karyawan <strong class="text-dark"><%= employee.full_name %></strong> siap dinonaktifkan dari sistem SamudraHRIS.</p>
                        
                        <div class="card bg-light text-start shadow-none border mt-4">
                            <div class="card-body p-3">
                                <h6>Ringkasan Offboarding:</h6>
                                <ul class="mb-0 text-muted" style="list-style-type: none; padding-left: 0;">
                                    <li><i class="mdi mdi-circle-small text-danger"></i> Tgl Efektif: <span id="summary_date" class="text-dark fw-bold"></span></li>
                                    <li><i class="mdi mdi-circle-small text-danger"></i> Alasan: <span id="summary_reason" class="text-dark fw-bold"></span></li>
                                    <li><i class="mdi mdi-circle-small text-danger"></i> Resolusi Finansial: <span id="summary_finance" class="text-dark fw-bold">CLEAR</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-light" id="btnBackToStep2"><i class="ti ti-arrow-left me-1"></i> Batal</button>
                        <button type="button" class="btn btn-danger btn-lg px-4" id="btnFinalizeOffboard">
                            <i class="ti ti-power text-white me-2"></i> FINALISASI NONAKTIF
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
