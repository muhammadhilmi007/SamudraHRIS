                                <label class="form-label">Uang Transport / BBM</label>
                                <input type="number" class="form-control" name="fuel_allowance" value="<%= formSal.fuel_allowance %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tarif Lembur (Override)</label>
                                <input type="number" class="form-control" name="overtime_rate_per_hour" value="<%= formSal.overtime_rate_per_hour %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bonus Tetap</label>
                                <input type="number" class="form-control" name="bonus" value="<%= formSal.bonus %>">
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Catatan Pembaruan <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="notes" placeholder="Misal: Kenaikan gaji tahunan 2025" required>
