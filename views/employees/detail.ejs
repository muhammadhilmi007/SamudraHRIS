<%- include('../partials/html') %>

<head>
    <%- include('../partials/title-meta', { title: title }) %>
    <%- include('../partials/head-css') %>
    <link href="/plugins/datatables/dataTables.bootstrap5.min.css" rel="stylesheet" type="text/css" />
    <link href="/plugins/datatables/responsive.bootstrap5.min.css" rel="stylesheet" type="text/css" />
    <link href="/plugins/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
    <style>
        .profile-user-box {
            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.05);
            margin-bottom: 20px;
            text-align: center;
        }
        .profile-user-box img {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 50%;
            border: 3px solid #dee2e6;
            margin-bottom: 15px;
        }
        .nav-pills .nav-link.active, .nav-pills .show>.nav-link {
            background-color: #6658dd;
            color: #fff;
        }
        .nav-pills .nav-link {
            color: #6c757d;
            font-weight: 500;
            padding: 10px 20px;
            border-radius: 0.25rem;
        }
        .timeline {
            border-left: 2px solid #eef2f7;
            padding-left: 20px;
            margin-top: 20px;
        }
        .timeline-item {
            position: relative;
            margin-bottom: 20px;
        }
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -27px;
            top: 5px;
            width: 12px;
            height: 12px;
            background-color: #6658dd;
            border-radius: 50%;
            border: 2px solid #fff;
            box-shadow: 0 0 0 2px #eef2f7;
        }
        .doc-card {
            border: 1px solid #eef2f7;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .doc-card:hover {
            box-shadow: 0 0 15px rgba(0,0,0,0.05);
            transform: translateY(-2px);
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include('../partials/menu') %>

        <div class="content-page">
            <div class="container-fluid">
                <%- include('../partials/page-title', { title: 'Profil Karyawan', subtitle: 'Karyawan / Detail' }) %>

                <div class="row">
                    <!-- Lembar Navigasi Kiri (Profile Singkat & Tabs) -->
                    <div class="col-xl-3 col-lg-4">
                        <div class="profile-user-box">
                            <div class="position-relative d-inline-block">
                                <img src="<%= employee.photo_url || '/images/users/user-1.jpg' %>" alt="user-profile" class="rounded-circle avatar-lg" id="profileImage">
                                <% if(employee.is_active) { %>
                                <div class="position-absolute bottom-0 end-0" style="margin-bottom: 20px; margin-right: 5px;">
                                    <label for="uploadPhotoInput" class="btn btn-sm btn-icon btn-primary rounded-circle shadow" title="Ganti Foto" style="cursor: pointer; padding: 4px 6px;">
                                        <i class="ti ti-camera"></i>
                                    </label>
                                    <input type="file" id="uploadPhotoInput" class="d-none" accept="image/jpeg, image/png, image/jpg">
                                </div>
                                <% } %>
                            </div>
                            <h4 class="mt-1 mb-1 font-18"><%= employee.full_name %></h4>
                            <p class="font-13 text-muted mb-2"><%= employee.position ? employee.position.name : '-' %> | <%= employee.branch ? employee.branch.name : '-' %></p>
                            
                            <% if(employee.status === 'KT') { %>
                                <span class="badge bg-primary px-2 py-1 fs-6">Tetap (KT)</span>
                            <% } else if(employee.status === 'KL') { %>
                                <span class="badge bg-success px-2 py-1 fs-6">Kontrak (KL)</span>
                            <% } else { %>
                                <span class="badge bg-warning text-dark px-2 py-1 fs-6">Magang</span>
                            <% } %>

                            <hr class="my-3">

                            <div class="text-start mt-3">
                                <p class="text-muted mb-2 font-13"><strong>ID Karyawan:</strong> <span class="ms-2"><%= employee.employee_code %></span></p>
                                <p class="text-muted mb-2 font-13"><strong>Bergabung:</strong> <span class="ms-2"><%= moment(employee.join_date).format('DD MMM YYYY') %></span></p>
                                <p class="text-muted mb-2 font-13"><strong>Masa Kerja:</strong> <span class="ms-2"><%= employee.work_tenure_years %> Tahun</span></p>
                            </div>

                            <% if(employee.qr_code_url) { %>
                                <div class="mt-3 text-center">
                                    <p class="text-muted font-12 mb-1">QR Code Absensi</p>
                                    <a href="<%= employee.qr_code_url %>" download="<%= employee.employee_code %>_QRCode.png" target="_blank">
                                        <img src="<%= employee.qr_code_url %>" alt="QR Code" style="width: 100px; height: 100px; border-radius: 4px;">
                                    </a>
                                </div>
                            <% } %>
                                <% if(employee.is_active) { %>
                                    <div class="dropdown mt-3">
                                        <button class="btn btn-primary dropdown-toggle w-100" type="button" id="actionDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                            Aksi Karyawan <i class="mdi mdi-chevron-down ms-1"></i>
                                        </button>
                                        <ul class="dropdown-menu w-100" aria-labelledby="actionDropdown">
                                            <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#mutationModal"><i class="ti ti-exchange text-warning me-2"></i> Mutasi / Pindah Cabang</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#offboardingModal"><i class="ti ti-user-x me-2"></i> Offboarding (Resign)</a></li>
                                        </ul>
                                    </div>
                                <% } else { %>
                                    <div class="mt-3 text-center">
                                        <div class="badge bg-danger fs-5 w-100 py-2">
                                            <i class="ti ti-user-off me-1"></i> NONAKTIF
                                        </div>
                                        <p class="text-danger fw-bold mt-2 mb-0"><%= moment(employee.resign_date).format('DD MMM YYYY') %></p>
                                        <small class="text-muted"><%= employee.resign_reason %></small>
                                    </div>
                                <% } %>
                        </div>

                        <!-- Sidebar Nav Tabs -->
                        <div class="card">
                            <div class="card-body p-0">
                                <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                                    <a class="nav-link active rounded-0 p-3 border-bottom" id="v-pills-profile-tab" data-bs-toggle="pill" href="#v-pills-profile" role="tab" aria-controls="v-pills-profile" aria-selected="true">
                                        <i class="ti ti-user me-2 font-16 align-middle"></i> Biodata Profil
                                    </a>
                                    <a class="nav-link rounded-0 p-3 border-bottom" id="v-pills-docs-tab" data-bs-toggle="pill" href="#v-pills-docs" role="tab" aria-controls="v-pills-docs" aria-selected="false">
                                        <i class="ti ti-folder me-2 font-16 align-middle"></i> Berkas Dokumen
                                    </a>
                                    <a class="nav-link rounded-0 p-3 border-bottom" id="v-pills-salary-tab" data-bs-toggle="pill" href="#v-pills-salary" role="tab" aria-controls="v-pills-salary" aria-selected="false">
                                        <i class="ti ti-wallet me-2 font-16 align-middle"></i> Konfigurasi Gaji
                                    </a>
                                    <a class="nav-link rounded-0 p-3 border-bottom" id="v-pills-attendance-tab" data-bs-toggle="pill" href="#v-pills-attendance" role="tab" aria-controls="v-pills-attendance" aria-selected="false">
                                        <i class="ti ti-calendar me-2 font-16 align-middle"></i> Riwayat Absensi
                                    </a>
                                    <a class="nav-link rounded-0 p-3" id="v-pills-receivable-tab" data-bs-toggle="pill" href="#v-pills-receivable" role="tab" aria-controls="v-pills-receivable" aria-selected="false">
                                        <i class="ti ti-receipt me-2 font-16 align-middle"></i> Rekap Piutang
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Konten Tab (Kanan) -->
                    <div class="col-xl-9 col-lg-8">
                        <div class="card">
                            <div class="card-body">
                                <div class="tab-content" id="v-pills-tabContent">
                                    
                                    <!-- TAB 1: PROFIL -->
                                    <div class="tab-pane fade show active" id="v-pills-profile" role="tabpanel" aria-labelledby="v-pills-profile-tab">
                                        <h4 class="header-title mb-3">Informasi Pribadi</h4>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-id"></i> NIK KTP</p>
                                                <h5 class="font-14 mt-0"><%= employee.nik %></h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-calendar-event"></i> Tempat, Tanggal Lahir</p>
                                                <h5 class="font-14 mt-0"><%= employee.birth_place || '-' %>, <%= employee.birth_date ? moment(employee.birth_date).format('DD MMM YYYY') : '-' %> (<%= employee.age_years %> Thn)</h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-users"></i> Jenis Kelamin & Agama</p>
                                                <h5 class="font-14 mt-0">
                                                    <%= employee.gender === 'L' ? 'Laki-Laki' : 'Perempuan' %> / 
                                                    <%= employee.religion || '-' %>
                                                </h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-heart"></i> Status Perkawinan</p>
                                                <h5 class="font-14 mt-0"><%= employee.marital_status || '-' %></h5>
                                            </div>
                                            <div class="col-md-12 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-map-pin"></i> Alamat Lengkap</p>
                                                <h5 class="font-14 mt-0"><%= employee.current_address ? `${employee.current_address}, ${employee.current_city}, ${employee.current_province}` : '-' %></h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-phone"></i> No. Handphone</p>
                                                <h5 class="font-14 mt-0"><%= employee.phone || '-' %></h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-mail"></i> Email</p>
                                                <h5 class="font-14 mt-0"><%= employee.email || '-' %></h5>
                                            </div>
                                        </div>

                                        <hr class="my-4">
                                        
                                        <h4 class="header-title mb-3">Informasi Kepegawaian</h4>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-building-store"></i> Cabang & Departemen</p>
                                                <h5 class="font-14 mt-0"><%= employee.branch ? employee.branch.name : '-' %> - <%= employee.department ? employee.department.name : '-' %></h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-briefcase"></i> Jabatan</p>
                                                <h5 class="font-14 mt-0"><%= employee.position ? employee.position.name : '-' %></h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-file-certificate"></i> Siklus Gaji</p>
                                                <h5 class="font-14 mt-0"><span class="badge bg-soft-info text-info"><%= employee.payment_cycle === 'monthly' ? 'Bulanan' : (employee.payment_cycle === 'weekly' ? 'Mingguan' : 'Harian') %></span></h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted mb-1"><i class="ti ti-certificate"></i> Masa Percobaan (Probation)</p>
                                                <h5 class="font-14 mt-0">
                                                    <%= employee.probation_end_date ? `Sampai ${moment(employee.probation_end_date).format('DD MMM YYYY')}` : '-' %>
                                                </h5>
                                            </div>
                                        </div>

                                        <hr class="my-4">

                                        <div class="row">
                                            <div class="col-md-6 mb-3 border-end">
                                                <h4 class="header-title mb-3">Informasi Bank</h4>
                                                <p class="text-muted mb-1">Nama Bank</p>
                                                <h5 class="font-14 mt-0"><%= employee.bank_name || '-' %></h5>
                                                
                                                <p class="text-muted mb-1 mt-2">Nomor Rekening</p>
                                                <h5 class="font-14 mt-0"><%= employee.bank_account_number ? employee.bank_account_number.replace(/.(?=.{4})/g, 'x') : '-' %></h5> <!-- Masked account -->
                                                
                                                <p class="text-muted mb-1 mt-2">Nama Pemilik Rekening</p>
                                                <h5 class="font-14 mt-0"><%= employee.bank_account_holder || '-' %></h5>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <h4 class="header-title mb-3">Kontak Darurat</h4>
                                                <p class="text-muted mb-1">Nama Kontak</p>
                                                <h5 class="font-14 mt-0"><%= employee.emergency_contact_name || '-' %></h5>
                                                
                                                <p class="text-muted mb-1 mt-2">Hubungan</p>
                                                <h5 class="font-14 mt-0"><%= employee.emergency_contact_relation || '-' %></h5>
                                                
                                                <p class="text-muted mb-1 mt-2">No. Handphone</p>
                                                <h5 class="font-14 mt-0"><%= employee.emergency_contact_phone || '-' %></h5>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- TAB 2: DOKUMEN -->
                                    <div class="tab-pane fade" id="v-pills-docs" role="tabpanel" aria-labelledby="v-pills-docs-tab">
                                        <div class="d-flex justify-content-between align-items-center mb-4">
                                            <h4 class="header-title mb-0">Berkas Dokumen</h4>
                                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadDocModal">
                                                <i class="ti ti-upload me-1"></i> Unggah Dokumen
                                            </button>
                                        </div>

                                        <div class="row" id="docGrid">
                                            <% if(documents.length === 0) { %>
                                                <div class="col-12 text-center py-5">
                                                    <i class="ti ti-files text-muted" style="font-size: 48px;"></i>
                                                    <h5 class="mt-3 text-muted">Belum ada dokumen yang diunggah</h5>
                                                </div>
                                            <% } else { %>
                                                <% documents.forEach(doc => { %>
                                                    <div class="col-md-6 col-xl-4 mb-3">
                                                        <div class="card doc-card p-2 h-100">
                                                            <div class="d-flex align-items-center">
                                                                <div class="avatar-sm me-3">
                                                                    <span class="avatar-title bg-soft-primary text-primary rounded">
                                                                        <% if(doc.file_type === 'pdf') { %>
                                                                            <i class="ti ti-file-text font-20"></i>
                                                                        <% } else if(doc.file_type === 'jpg' || doc.file_type === 'png' || doc.file_type === 'jpeg') { %>
                                                                            <i class="ti ti-photo font-20"></i>
                                                                        <% } else { %>
                                                                            <i class="ti ti-file font-20"></i>
                                                                        <% } %>
                                                                    </span>
                                                                </div>
                                                                <div class="flex-grow-1 overflow-hidden">
                                                                    <h5 class="font-14 mt-0 mb-1 text-truncate"><a href="javascript:void(0);" class="text-dark"><%= doc.doc_name %></a></h5>
                                                                    <p class="text-muted font-12 mb-0"><%= doc.doc_type.toUpperCase() %> • <%= moment(doc.uploaded_at).format('DD MMM YYYY') %></p>
                                                                </div>
                                                                <div class="dropdown">
                                                                    <a href="#" class="dropdown-toggle text-muted font-18" data-bs-toggle="dropdown" aria-expanded="false">
                                                                        <i class="ti ti-dots-vertical"></i>
                                                                    </a>
                                                                    <div class="dropdown-menu dropdown-menu-end">
                                                                        <a href="<%= doc.file_url %>" target="_blank" class="dropdown-item"><i class="ti ti-eye me-1"></i> Lihat Berkas</a>
                                                                        <a href="<%= doc.file_url %>" download class="dropdown-item"><i class="ti ti-download me-1"></i> Unduh</a>
                                                                        <div class="dropdown-divider"></div>
                                                                        <a href="javascript:void(0);" class="dropdown-item text-danger btn-delete-doc" data-id="<%= doc._id %>"><i class="ti ti-trash me-1"></i> Hapus</a>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                <% }) %>
                                            <% } %>
                                        </div>
                                    </div>

                                    <!-- TAB 3: GAJI -->
                                    <div class="tab-pane fade" id="v-pills-salary" role="tabpanel" aria-labelledby="v-pills-salary-tab">
                                        <div class="d-flex justify-content-between align-items-center mb-4">
                                            <h4 class="header-title mb-0">Konfigurasi Gaji Saat Ini</h4>
                                            <button class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#updateSalaryModal">
                                                <i class="ti ti-edit me-1"></i> Perbarui Gaji
                                            </button>
                                        </div>

                                        <% if(currentSalary) { %>
                                            <div class="table-responsive mb-4">
                                                <table class="table table-bordered table-sm mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th style="width: 40%">Komponen</th>
                                                            <th style="width: 30%">Nominal (Rp)</th>
                                                            <th style="width: 30%">Catatan / Keterangan</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr><td>1. Gaji Pokok</td><td class="text-end fw-bold"><%= currentSalary.base_salary.toLocaleString('id-ID') %></td><td>-</td></tr>
                                                        <tr><td>2. Tunjangan Lama Kerja</td><td class="text-end"><%= currentSalary.tenure_allowance.toLocaleString('id-ID') %></td><td>-</td></tr>
                                                        <tr><td>3. Tunjangan Jabatan</td><td class="text-end"><%= currentSalary.position_allowance.toLocaleString('id-ID') %></td><td>-</td></tr>
                                                        <tr><td>4. Tunjangan Kinerja</td><td class="text-end"><%= currentSalary.performance_allowance.toLocaleString('id-ID') %></td><td>-</td></tr>
                                                        <tr class="table-light"><th colspan="3">Pendapatan Variabel</th></tr>
                                                        <tr><td>5. Tarif Harian (jika dihit/hari)</td><td class="text-end"><%= currentSalary.daily_rate.toLocaleString('id-ID') %> / hari</td><td>-</td></tr>
                                                        <tr><td>6. Uang Makan / Kehadiran</td><td class="text-end"><%= currentSalary.meal_allowance.toLocaleString('id-ID') %> / hari</td><td>-</td></tr>
                                                        <tr><td>7. Uang BBM / Transport</td><td class="text-end"><%= currentSalary.fuel_allowance.toLocaleString('id-ID') %></td><td>(Bulanan)</td></tr>
                                                        <tr><td>8. Tarif Lembur Spesifik</td><td class="text-end"><%= currentSalary.overtime_rate_per_hour.toLocaleString('id-ID') %> / jam</td><td>Override tarif cabang</td></tr>
                                                        <tr><td>9. Bonus Tetap</td><td class="text-end"><%= currentSalary.bonus.toLocaleString('id-ID') %></td><td>-</td></tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        <% } else { %>
                                            <div class="alert alert-warning"><i class="ti ti-alert-triangle me-2"></i> Konfigurasi gaji belum diatur untuk karyawan ini.</div>
                                        <% } %>

                                        <h4 class="header-title mt-4 mb-3">Timeline Riwayat Perubahan Gaji</h4>
                                        <div class="timeline">
                                            <% salaryConfigs.forEach(conf => { %>
                                                <div class="timeline-item">
                                                    <h5 class="mt-0 mb-1"><%= moment(conf.effective_date).format('DD MMM YYYY HH:mm') %></h5>
                                                    <p class="text-muted font-13 mb-1">
                                                        Oleh: <b><%= conf.created_by ? conf.created_by.name : 'Sistem' %></b>
                                                        <% if(conf.is_current) { %>
                                                            <span class="badge bg-success ms-2">Aktif Sekarang</span>
                                                        <% } else { %>
                                                            <span class="badge bg-secondary ms-2">Selesai: <%= moment(conf.end_date).format('DD MMM YYYY') %></span>
                                                        <% } %>
                                                    </p>
                                                    <p class="text-dark font-14 mb-0">Catatan: <%= conf.notes || 'Tidak ada catatan pembaruan' %></p>
                                                </div>
                                            <% }) %>
                                        </div>
                                    </div>

                                    <!-- TAB 4: ABSENSI -->
                                    <div class="tab-pane fade" id="v-pills-attendance" role="tabpanel" aria-labelledby="v-pills-attendance-tab">
                                        <h4 class="header-title mb-4">Rekap & Riwayat Absensi (30 Hari Terakhir)</h4>
                                        
                                        <!-- Mini Rekap Placeholder -->
                                        <div class="row mb-4">
                                            <div class="col-md-3">
                                                <div class="card bg-soft-success border-success border">
                                                    <div class="card-body p-2 text-center">
                                                        <h4 class="text-success m-0"><%= attendances.filter(a => a.status === 'present' || a.status === 'late').length %></h4>
                                                        <span class="font-12">Hadir/Telat</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card bg-soft-info border-info border">
                                                    <div class="card-body p-2 text-center">
                                                        <h4 class="text-info m-0"><%= attendances.filter(a => a.status === 'leave').length %></h4>
                                                        <span class="font-12">Izin/Cuti</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card bg-soft-warning border-warning border">
                                                    <div class="card-body p-2 text-center">
                                                        <h4 class="text-warning m-0"><%= attendances.filter(a => a.status === 'sick').length %></h4>
                                                        <span class="font-12">Sakit</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card bg-soft-danger border-danger border">
                                                    <div class="card-body p-2 text-center">
                                                        <h4 class="text-danger m-0"><%= attendances.filter(a => a.status === 'absent').length %></h4>
                                                        <span class="font-12">Alpa (Tanpa Keterangan)</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <table class="table table-sm table-centered table-nowrap mb-0 w-100" id="attendanceTable">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Tanggal</th>
                                                    <th>Check In</th>
                                                    <th>Check Out</th>
                                                    <th>Durasi</th>
                                                    <th>Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if(attendances.length === 0) { %>
                                                    <tr><td colspan="5" class="text-center">Belum ada riwayat absensi.</td></tr>
                                                <% } else { %>
                                                    <% attendances.forEach(att => { %>
                                                        <tr>
                                                            <td><%= moment(att.attendance_date).format('DD MMM YYYY') %></td>
                                                            <td><%= att.check_in_time ? moment(att.check_in_time).format('HH:mm') : '-' %></td>
                                                            <td><%= att.check_out_time ? moment(att.check_out_time).format('HH:mm') : '-' %></td>
                                                            <td><%= att.work_duration_minutes ? (att.work_duration_minutes / 60).toFixed(1) + ' Jam' : '-' %></td>
                                                            <td>
                                                                <% if(att.status === 'present') { %><span class="badge bg-success">Hadir</span><% } %>
                                                                <% if(att.status === 'late') { %><span class="badge bg-warning">Terlambat</span><% } %>
                                                                <% if(att.status === 'leave') { %><span class="badge bg-info">Izin</span><% } %>
                                                                <% if(att.status === 'sick') { %><span class="badge bg-warning text-dark">Sakit</span><% } %>
                                                                <% if(att.status === 'absent') { %><span class="badge bg-danger">Alpa</span><% } %>
                                                            </td>
                                                        </tr>
                                                    <% }) %>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>

                                    <!-- TAB 5: PIUTANG -->
                                    <div class="tab-pane fade" id="v-pills-receivable" role="tabpanel" aria-labelledby="v-pills-receivable-tab">
                                        <h4 class="header-title mb-4">Summary & Riwayat Piutang Karyawan</h4>
                                        
                                        <div class="row text-center mb-4">
                                            <div class="col-md-4">
                                                <div class="p-3 border rounded">
                                                    <p class="text-muted font-13 mb-1">Total Pinjaman</p>
                                                    <h4 class="text-primary m-0">Rp <%= receivableSummary.totalReceivable.toLocaleString('id-ID') %></h4>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="p-3 border rounded">
                                                    <p class="text-muted font-13 mb-1">Sudah Dibayar</p>
                                                    <h4 class="text-success m-0">Rp <%= receivableSummary.totalPaid.toLocaleString('id-ID') %></h4>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="p-3 border rounded bg-soft-danger">
                                                    <p class="text-danger font-13 mb-1">Sisa Piutang</p>
                                                    <h4 class="text-danger m-0">Rp <%= receivableSummary.totalRemaining.toLocaleString('id-ID') %></h4>
                                                </div>
                                            </div>
                                        </div>

                                        <table class="table table-sm table-centered table-nowrap mb-0 w-100" id="receivableTable">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>No. Piutang</th>
                                                    <th>Tgl Pengajuan</th>
                                                    <th>Total Hutang</th>
                                                    <th>Cicilan/Bulan</th>
                                                    <th>Sisa</th>
                                                    <th>Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if(receivables.length === 0) { %>
                                                    <tr><td colspan="6" class="text-center">Tidak ada catatan piutang.</td></tr>
                                                <% } else { %>
                                                    <% receivables.forEach(rec => { %>
                                                        <tr>
                                                            <td><a href="#"><b><%= rec.receivable_number %></b></a></td>
                                                            <td><%= moment(rec.request_date).format('DD MMM YYYY') %></td>
                                                            <td>Rp <%= rec.amount.toLocaleString('id-ID') %></td>
                                                            <td>Rp <%= rec.installment_amount.toLocaleString('id-ID') %> (<%= rec.tenor_months %>x)</td>
                                                            <td class="text-danger fw-bold">Rp <%= rec.remaining_amount.toLocaleString('id-ID') %></td>
                                                            <td>
                                                                <% if(rec.status === 'draft') { %><span class="badge bg-secondary">Draft</span><% } %>
                                                                <% if(rec.status === 'active') { %><span class="badge bg-primary">Aktif</span><% } %>
                                                                <% if(rec.status === 'paid') { %><span class="badge bg-success">Lunas</span><% } %>
                                                            </td>
                                                        </tr>
                                                    <% }) %>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Modal Upload Dokumen -->
    <%- include('mutation-form') %>
    <%- include('offboarding') %>
    <div class="modal fade" id="uploadDocModal" tabindex="-1" aria-labelledby="uploadDocModalLabel" aria-hidden="true">
