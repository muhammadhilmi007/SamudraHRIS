                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tunjangan Kinerja</label>
                                <input type="number" class="form-control" name="performance_allowance" value="<%= formSal.performance_allowance %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tarif Harian</label>
                                <input type="number" class="form-control" name="daily_rate" value="<%= formSal.daily_rate %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Uang Makan / Kehadiran</label>
                                <input type="number" class="form-control" name="meal_allowance" value="<%= formSal.meal_allowance %>">
                            </div>
