    </div>

    <%- include('../partials/footer-scripts') %>
    <script src="/plugins/jquery/jquery.min.js"></script>
    <script src="/plugins/datatables/dataTables.min.js"></script>
    <script src="/plugins/datatables/dataTables.bootstrap5.min.js"></script>
    <script src="/plugins/datatables/dataTables.responsive.min.js"></script>
    <script src="/plugins/datatables/responsive.bootstrap5.min.js"></script>
    <script src="/plugins/sweetalert2/sweetalert2.min.js"></script>
    <script src="/plugins/moment/moment.min.js"></script>

    <script>
        $(document).ready(function() {
            const employeeId = '<%= employee._id %>';

            // Document Upload Handler
            $('#uploadDocForm').on('submit', function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                $('#btnUploadDoc').prop('disabled', true).text('Mengunggah...');

                fetch(`/api/v1/employees/${employeeId}/documents`, {
                    method: 'POST',
                    body: formData
                })
                .then(res => res.json())
                .then(res => {
                    $('#btnUploadDoc').prop('disabled', false).text('Unggah & Simpan');
                    if(res.success) {
                        $('#uploadDocModal').modal('hide');
                        Swal.fire('Berhasil', 'Dokumen berhasil diunggah', 'success').then(() => {
                            location.reload(); // Reload to show new doc in grid
                        });
                    } else {
                        Swal.fire('Gagal', res.message || 'Terjadi kesalahan sistem', 'error');
                    }
                })
                .catch(err => {
                    $('#btnUploadDoc').prop('disabled', false).text('Unggah & Simpan');
                    Swal.fire('Error', 'Kesalahan jaringan', 'error');
                });
            });

            // Delete Document Handler
            $('.btn-delete-doc').on('click', function() {
                const docId = $(this).data('id');
                Swal.fire({
                    title: 'Hapus Dokumen?',
                    text: 'Dokumen ini akan dihapus permanen dari sistem.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#8a969c',
                    confirmButtonText: 'Ya, Hapus'
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch(`/api/v1/employees/documents/${docId}`, { method: 'DELETE' })
                        .then(res => res.json())
                        .then(res => {
                            if(res.success) {
                                Swal.fire('Terhapus', 'Dokumen berhasil dihapus', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Gagal', res.message, 'error');
                            }
                        });
                    }
                });
            });

            // Salary Config Update Handler
            $('#updateSalaryForm').on('submit', function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                const data = Object.fromEntries(formData.entries());
                
                $('#btnUpdateSalary').prop('disabled', true).text('Menyimpan...');

                fetch(`/api/v1/employees/${employeeId}/salary-config`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                })
                .then(res => res.json())
                .then(res => {
                    $('#btnUpdateSalary').prop('disabled', false).text('Simpan Konfigurasi');
                    if(res.success) {
                        $('#updateSalaryModal').modal('hide');
                        Swal.fire('Berhasil', 'Konfigurasi gaji baru berhasil diterapkan', 'success').then(() => {
                            location.reload(); // Reload to refresh timeline and current values
                        });
                    } else {
                        Swal.fire('Gagal', res.message || 'Error', 'error');
                    }
                });
            });

            // Init simple DataTables for Attendance and Receivable if needed (client side since it's already generated)
            if($('#attendanceTable tbody tr').length > 0 && !$('#attendanceTable tbody tr td').hasClass('text-center')) {
               $('#attendanceTable').DataTable({ responsive: true, pageLength: 10, lengthChange: false, searching: false, info: false });
            }
            if($('#receivableTable tbody tr').length > 0 && !$('#receivableTable tbody tr td').hasClass('text-center')) {
               $('#receivableTable').DataTable({ responsive: true, pageLength: 5, lengthChange: false, searching: false, info: false });
            }

            // ==========================================
            // JS Logic for Mutation & Offboarding
            // ==========================================
            const baseUrl = '/api/v1/employees/' + employeeId;

            // --- UPLOAD FOTO PROFIL ---
            $('#uploadPhotoInput').on('change', function() {
                const file = this.files[0];
                if (!file) return;

                if (file.size > 5 * 1024 * 1024) {
                    Swal.fire('Error', 'Ukuran gambar maksimal 5MB.', 'error');
                    this.value = '';
                    return;
                }

                const fd = new FormData();
                fd.append('photo', file);

                Swal.fire({
                    title: 'Mengunggah Foto...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/api/v1/employees/<%= employee._id %>/photo',
                    type: 'POST',
                    data: fd,
                    processData: false,
                    contentType: false,
                    success: function(res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Berhasil',
                                text: 'Foto profil telah diperbarui',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        }
                    },
                    error: function(xhr) {
                        let msg = 'Gagal mengunggah foto.';
                        if(xhr.responseJSON && xhr.responseJSON.error) msg = xhr.responseJSON.error.message;
                        Swal.fire('Error', msg, 'error');
                        $('#uploadPhotoInput').val('');
                    }
                });
            });

            // --- MUTASI ---
            <% if(employee.is_active) { %>
            // Load Branches for Mutation
            $('#mutationModal').on('show.bs.modal', function () {
                if($('#mut_branch_id option').length <= 1) { // Load only once
                    $.ajax({
                        url: '/api/v1/branches',
                        type: 'GET',
                        success: function(res) {
                            if(res.success && res.data) {
                                res.data.forEach(b => {
                                    if(b._id !== '<%= employee.branch_id ? employee.branch_id._id : "" %>') {
                                        $('#mut_branch_id').append(new Option(b.name, b._id));
                                    }
                                });
                            }
                        }
                    });
                }
            });

            // Cascade Branch -> Department
            $('#mut_branch_id').on('change', function() {
                const branchId = $(this).val();
                $('#mut_department_id').html('<option value="">--- Pilih Departemen ---</option>').prop('disabled', true);
                $('#mut_position_id').html('<option value="">--- Pilih Jabatan ---</option>').prop('disabled', true);
                if(!branchId) return;

                $.ajax({
                    url: `/api/v1/departments?branch_id=${branchId}`,
                    type: 'GET',
                    success: function(res) {
                        if(res.success && res.data) {
                            $('#mut_department_id').prop('disabled', false);
                            res.data.forEach(d => {
                                const sel = (d._id === '<%= employee.department_id ? employee.department_id._id : "" %>') ? true : false;
                                $('#mut_department_id').append(new Option(d.name, d._id, sel, sel));
                            });
                            $('#mut_department_id').trigger('change');
                        }
                    }
                });
            });

            // Cascade Department -> Position
            $('#mut_department_id').on('change', function() {
                const deptId = $(this).val();
                $('#mut_position_id').html('<option value="">--- Pilih Jabatan ---</option>').prop('disabled', true);
                if(!deptId) return;

                $.ajax({
                    url: `/api/v1/positions?department_id=${deptId}`,
                    type: 'GET',
                    success: function(res) {
                        if(res.success && res.data) {
                            $('#mut_position_id').prop('disabled', false);
                            res.data.forEach(p => {
                                const sel = (p._id === '<%= employee.position_id ? employee.position_id._id : "" %>') ? true : false;
                                $('#mut_position_id').append(new Option(p.name, p._id, sel, sel));
                            });
                        }
                    }
                });
            });

            // Submit Mutation
            $('#formMutation').on('submit', function(e) {
                e.preventDefault();
                const btn = $('#btnSubmitMutation');
                const spinner = btn.find('.spinner-border');
                
                btn.prop('disabled', true);
                spinner.removeClass('d-none');

                const formData = {
                    to_branch_id: $('#mut_branch_id').val(),
                    to_department_id: $('#mut_department_id').val(),
                    to_position_id: $('#mut_position_id').val(),
                    effective_date: $('#mut_effective_date').val(),
                    reason: $('#mut_reason').val()
                };

                $.ajax({
                    url: baseUrl + '/mutate',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function(res) {
                        if(res.success) {
                            $('#mutationModal').modal('hide');
                            Swal.fire('Berhasil!', 'Mutasi berhasil diproses. Memuat ulang data...', 'success')
                            .then(() => location.reload());
                        }
                    },
                    error: function(xhr) {
                        btn.prop('disabled', false);
                        spinner.addClass('d-none');
                        let msg = 'Gagal memproses mutasi.';
                        if(xhr.responseJSON && xhr.responseJSON.error) msg = xhr.responseJSON.error.message;
                        Swal.fire('Error', msg, 'error');
                    }
                });
            });

            // --- OFFBOARDING ---
            let offboardPayload = {};

            $('#formInitOffboard').on('submit', function(e) {
                e.preventDefault();
                const btn = $('#btnInitOffboard');
                
                offboardPayload = {
                    last_working_date: $('#offboard_lwd').val(),
                    resign_date: $('#offboard_resign_date').val(),
                    resign_reason: $('#offboard_reason').val()
                };

                btn.prop('disabled', true).html('<i class="mdi mdi-spin mdi-loading"></i> Memeriksa...');

                $.ajax({
                    url: baseUrl + '/offboard',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(offboardPayload),
                    success: function(res) {
                        if(res.success) {
                            // Ready to finalize (No Debt)
                            $('#summary_date').text(moment(offboardPayload.resign_date).format('DD MMM YYYY'));
                            $('#summary_reason').text(offboardPayload.resign_reason);
                            
                            $('#step1-indicator').removeClass('bg-danger text-white').addClass('bg-light text-muted');
                            $('#step1-text').removeClass('text-danger').addClass('text-muted');
                            $('#step3-indicator').removeClass('bg-light text-muted').addClass('bg-danger text-white');
                            $('#step3-text').removeClass('text-muted').addClass('text-danger');
                            
                            $('#offboard-step-1').addClass('d-none');
                            $('#offboard-step-3').removeClass('d-none');
                        }
                    },
                    error: function(xhr) {
                        btn.prop('disabled', false).html('Lanjut <i class="ti ti-arrow-right ms-1"></i>');
                        if(xhr.status === 409 && xhr.responseJSON && xhr.responseJSON.error.code === 'ACTIVE_RECEIVABLE_EXISTS') {
                            // Debt Found, proceed to Step 2
                            const debtData = xhr.responseJSON.error.data;
                            $('#offboard_debt_amount').text('Rp ' + debtData.total_remaining.toLocaleString('id-ID'));
                            
                            $('#step1-indicator').removeClass('bg-danger text-white').addClass('bg-light text-muted');
                            $('#step1-text').removeClass('text-danger').addClass('text-muted');
                            $('#step2-indicator').removeClass('bg-light text-muted').addClass('bg-danger text-white');
                            $('#step2-text').removeClass('text-muted').addClass('text-danger');
                            
                            $('#offboard-step-1').addClass('d-none');
                            $('#offboard-step-2').removeClass('d-none');
                        } else {
                            let msg = 'Gagal memproses.';
                            if(xhr.responseJSON && xhr.responseJSON.error) msg = xhr.responseJSON.error.message;
                            Swal.fire('Error', msg, 'error');
                        }
                    }
                });
            });

            $('#btnBackToStep1').on('click', function() {
                $('#step2-indicator').removeClass('bg-danger text-white').addClass('bg-light text-muted');
                $('#step2-text').removeClass('text-danger').addClass('text-muted');
                $('#step1-indicator').removeClass('bg-light text-muted').addClass('bg-danger text-white');
                $('#step1-text').removeClass('text-muted').addClass('text-danger');
                
                $('#offboard-step-2').addClass('d-none');
                $('#offboard-step-1').removeClass('d-none');
            });

            $('#formResolveDebt').on('submit', function(e) {
                e.preventDefault();
                const btn = $('#btnResolveDebt');
                const resolution = $('input[name="resolution_method"]:checked').val();
                
                btn.prop('disabled', true).html('<i class="mdi mdi-spin mdi-loading"></i> Menyimpan...');

                $.ajax({
                    url: baseUrl + '/offboard/resolve-receivable',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ resolution_method: resolution }),
                    success: function(res) {
                        if(res.success) {
                            $('#summary_date').text(moment(offboardPayload.resign_date).format('DD MMM YYYY'));
                            $('#summary_reason').text(offboardPayload.resign_reason);
                            $('#summary_finance').text(resolution === 'salary_deduction' ? 'POTONG GAJI (PRORATA)' : 'PELUNASAN LANGSUNG (DILUAR SISTEM)');
                            
                            $('#step2-indicator').removeClass('bg-danger text-white').addClass('bg-light text-muted');
                            $('#step2-text').removeClass('text-danger').addClass('text-muted');
                            $('#step3-indicator').removeClass('bg-light text-muted').addClass('bg-danger text-white');
                            $('#step3-text').removeClass('text-muted').addClass('text-danger');
                            
                            $('#offboard-step-2').addClass('d-none');
                            $('#offboard-step-3').removeClass('d-none');
                        }
                    },
                    error: function(xhr) {
                        btn.prop('disabled', false).html('Konfirmasi Resolusi & Lanjut <i class="ti ti-arrow-right ms-1"></i>');
                        let msg = 'Gagal menyimpan pilihan.';
                        if(xhr.responseJSON && xhr.responseJSON.error) msg = xhr.responseJSON.error.message;
                        Swal.fire('Error', msg, 'error');
                    }
                });
            });

            $('#btnBackToStep2').on('click', function() {
                if($('#summary_finance').text() === 'CLEAR') {
                    $('#step3-indicator').removeClass('bg-danger text-white').addClass('bg-light text-muted');
                    $('#step3-text').removeClass('text-danger').addClass('text-muted');
                    $('#step1-indicator').removeClass('bg-light text-muted').addClass('bg-danger text-white');
                    $('#step1-text').removeClass('text-muted').addClass('text-danger');
                    
                    $('#offboard-step-3').addClass('d-none');
                    $('#offboard-step-1').removeClass('d-none');
                } else {
                    $('#step3-indicator').removeClass('bg-danger text-white').addClass('bg-light text-muted');
                    $('#step3-text').removeClass('text-danger').addClass('text-muted');
                    $('#step2-indicator').removeClass('bg-light text-muted').addClass('bg-danger text-white');
                    $('#step2-text').removeClass('text-muted').addClass('text-danger');
                    
                    $('#offboard-step-3').addClass('d-none');
                    $('#offboard-step-2').removeClass('d-none');
                    $('#btnResolveDebt').prop('disabled', false).html('Konfirmasi Resolusi & Lanjut <i class="ti ti-arrow-right ms-1"></i>');
                }
            });

            $('#btnFinalizeOffboard').on('click', function() {
                Swal.fire({
                    title: 'Konfirmasi Final!',
                    html: `Ketik <b>NONAKTIFKAN</b> di bawah ini untuk mengonfirmasi pemberhentian karyawan.`,
                    input: 'text',
                    inputAttributes: {
                        autocapitalize: 'off',
                        autocomplete: 'off'
                    },
                    showCancelButton: true,
                    confirmButtonText: 'Proses Offboarding',
                    cancelButtonText: 'Batal',
                    confirmButtonColor: '#d33',
                    showLoaderOnConfirm: true,
                    preConfirm: (inputValue) => {
                        if (inputValue !== 'NONAKTIFKAN') {
                            Swal.showValidationMessage('Teks konfirmasi tidak cocok!');
                            return false;
                        }
                        
                        return $.ajax({
                            url: baseUrl + '/offboard/finalize',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(offboardPayload)
                        }).catch(err => {
                            let msg = 'Terjadi kesalahan sistem.';
                            if(err.responseJSON && err.responseJSON.error) msg = err.responseJSON.error.message;
                            Swal.showValidationMessage(`Request failed: ${msg}`);
                        });
                    },
                    allowOutsideClick: () => !Swal.isLoading()
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#offboardingModal').modal('hide');
                        Swal.fire({
                            title: 'Berhasil!',
                            text: 'Karyawan telah dinonaktifkan dari sistem.',
                            icon: 'success'
                        }).then(() => {
                            location.reload();
                        });
                    }
                });
            });
            <% } %>
        });
    </script>
</body>
</html>
