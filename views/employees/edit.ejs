<%- include('../partials/html') %>

<head>
    <%- include('../partials/title-meta', { title: 'Edit Data Karyawan' }) %>
    <%- include('../partials/head-css') %>
    <link href="/plugins/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
    <style>
        .required-star:after {
            content: '*';
            color: red;
            margin-left: 4px;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include('../partials/menu') %>

        <div class="content-page">
            <div class="container-fluid">
                <%- include('../partials/page-title', { title: 'Edit Karyawan', subtitle: 'Karyawan' }) %>

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h4 class="header-title mb-4">Formulir Edit Data: <%= employee.full_name %></h4>
                                
                                <form id="formEditEmployee" class="needs-validation" novalidate>
                                    <h5 class="mb-3 text-uppercase bg-light p-2"><i class="ti ti-user-circle me-1"></i> Informasi Dasar</h5>
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label required-star">Nama Lengkap</label>
                                            <input type="text" class="form-control" name="full_name" value="<%= employee.full_name %>" required>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">NIK (Tidak dapat diubah)</label>
                                            <input type="text" class="form-control" value="<%= employee.nik %>" readonly>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Tempat Lahir</label>
                                            <input type="text" class="form-control" name="birth_place" value="<%= employee.birth_place %>">
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Tanggal Lahir</label>
                                            <input type="date" class="form-control" name="birth_date" value="<%= employee.birth_date ? moment(employee.birth_date).format('YYYY-MM-DD') : '' %>" required>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Jenis Kelamin</label>
                                            <select class="form-select" name="gender" required>
                                                <option value="L" <%= employee.gender === 'L' ? 'selected' : '' %>>Laki-laki</option>
                                                <option value="P" <%= employee.gender === 'P' ? 'selected' : '' %>>Perempuan</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Agama</label>
                                            <select class="form-select" name="religion">
                                                <% const religions = ['Islam', 'Kristen', 'Katolik', 'Hindu', 'Buddha', 'Konghucu', 'Lainnya']; %>
                                                <% religions.forEach(r => { %>
                                                    <option value="<%= r %>" <%= employee.religion === r ? 'selected' : '' %>><%= r %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Status Pernikahan</label>
                                            <select class="form-select" name="marital_status">
                                                <% const marStatus = ['Belum Menikah', 'Menikah', 'Cerai']; %>
                                                <% marStatus.forEach(m => { %>
                                                    <option value="<%= m %>" <%= employee.marital_status === m ? 'selected' : '' %>><%= m %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Golongan Darah</label>
                                            <select class="form-select" name="blood_type">
                                                <% const bloodTypes = ['-', 'A', 'B', 'AB', 'O']; %>
                                                <% bloodTypes.forEach(b => { %>
                                                    <option value="<%= b %>" <%= employee.blood_type === b ? 'selected' : '' %>><%= b %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                    </div>

                                    <h5 class="mb-3 text-uppercase bg-light p-2 mt-4"><i class="ti ti-map-pin me-1"></i> Kontak & Alamat</h5>
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label required-star">No. Telepon / WhatsApp</label>
                                            <input type="text" class="form-control" name="phone" value="<%= employee.phone %>" required>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Email Pribadi</label>
                                            <input type="email" class="form-control" name="email" value="<%= employee.email %>">
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-12 mb-3">
                                            <label class="form-label">Alamat Lengkap</label>
                                            <textarea class="form-control" name="address" rows="2"><%= employee.address %></textarea>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Kota / Kabupaten</label>
                                            <input type="text" class="form-control" name="city" value="<%= employee.city %>">
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Provinsi</label>
                                            <input type="text" class="form-control" name="province" value="<%= employee.province %>">
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Kode Pos</label>
                                            <input type="text" class="form-control" name="postal_code" value="<%= employee.postal_code %>">
                                        </div>
                                    </div>

                                    <h5 class="mb-3 text-uppercase bg-light p-2 mt-4"><i class="ti ti-briefcase me-1"></i> Penempatan Kerja</h5>
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Cabang</label>
                                            <select class="form-select" name="branch_id" id="branchSelect" required>
                                                <option value="">Pilih Cabang</option>
                                                <% branches.forEach(b => { %>
                                                    <option value="<%= b._id %>" <%= employee.branch_id && employee.branch_id._id.toString() === b._id.toString() ? 'selected' : '' %>><%= b.name %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Departemen</label>
                                            <select class="form-select" name="department_id" id="deptSelect" required>
                                                <option value="<%= employee.department_id ? employee.department_id._id : '' %>" selected>Terpilih Saat Ini</option>
                                            </select>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Jabatan</label>
                                            <select class="form-select" name="position_id" id="posSelect" required>
                                                <option value="<%= employee.position_id ? employee.position_id._id : '' %>" selected>Terpilih Saat Ini</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Status Karyawan</label>
                                            <select class="form-select" name="status" required>
                                                <option value="KT" <%= employee.status === 'KT' ? 'selected' : '' %>>Karyawan Tetap (KT)</option>
                                                <option value="KL" <%= employee.status === 'KL' ? 'selected' : '' %>>Karyawan Kontrak (KL)</option>
                                                <option value="Magang" <%= employee.status === 'Magang' ? 'selected' : '' %>>Magang</option>
                                            </select>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Tanggal Bergabung</label>
                                            <input type="date" class="form-control" name="join_date" value="<%= employee.join_date ? moment(employee.join_date).format('YYYY-MM-DD') : '' %>" required>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Siklus Pembayaran</label>
                                            <select class="form-select" name="payment_cycle" required>
                                                <option value="monthly" <%= employee.payment_cycle === 'monthly' ? 'selected' : '' %>>Bulanan</option>
                                                <option value="weekly" <%= employee.payment_cycle === 'weekly' ? 'selected' : '' %>>Mingguan</option>
                                                <option value="daily" <%= employee.payment_cycle === 'daily' ? 'selected' : '' %>>Harian</option>
                                            </select>
                                        </div>
                                    </div>

                                    <h5 class="mb-3 text-uppercase bg-light p-2 mt-4"><i class="ti ti-phone-call me-1"></i> Kontak Darurat</h5>
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Nama Kontak</label>
                                            <input type="text" class="form-control" name="emergency_contact.name" value="<%= employee.emergency_contact ? employee.emergency_contact.name : '' %>" required>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Hubungan</label>
                                            <input type="text" class="form-control" name="emergency_contact.relationship" value="<%= employee.emergency_contact ? employee.emergency_contact.relationship : '' %>" required>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">No. Telepon</label>
                                            <input type="text" class="form-control" name="emergency_contact.phone" value="<%= employee.emergency_contact ? employee.emergency_contact.phone : '' %>" required>
                                        </div>
                                    </div>

                                    <h5 class="mb-3 text-uppercase bg-light p-2 mt-4"><i class="ti ti-building-bank me-1"></i> Rekening Bank</h5>
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Nama Bank</label>
                                            <input type="text" class="form-control" name="bank_account.bank_name" value="<%= employee.bank_account ? employee.bank_account.bank_name : '' %>" required>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Nomor Rekening</label>
                                            <input type="text" class="form-control" name="bank_account.account_number" value="<%= employee.bank_account ? employee.bank_account.account_number : '' %>" required>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label required-star">Atas Nama</label>
                                            <input type="text" class="form-control" name="bank_account.account_holder_name" value="<%= employee.bank_account ? employee.bank_account.account_holder_name : '' %>" required>
                                        </div>
                                    </div>

                                    <div class="text-end mt-4">
                                        <a href="/karyawan" class="btn btn-light me-2">Batal</a>
                                        <button type="submit" class="btn btn-primary" id="btnSubmit">
                                            <i class="ti ti-device-floppy me-1"></i> Simpan Perubahan
                                        </button>
                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <%- include('../partials/footer-scripts') %>
    <script src="/plugins/jquery/jquery.min.js"></script>
    <script src="/plugins/sweetalert2/sweetalert2.min.js"></script>

    <script>
        $(document).ready(function() {
            const currentDeptId = '<%= employee.department_id ? (employee.department_id._id || employee.department_id) : "" %>';
            const currentPosId = '<%= employee.position_id ? (employee.position_id._id || employee.position_id) : "" %>';

            // Load initial depts
            function loadDepartments(branchId, selectedDeptId) {
                if(!branchId) return;
                fetch(`/api/v1/departments?branch_id=${branchId}`)
                    .then(res => res.json())
                    .then(res => {
                        let opts = '<option value="">Pilih Departemen</option>';
                        res.data.forEach(d => {
                            const sel = d._id === selectedDeptId ? 'selected' : '';
                            opts += `<option value="${d._id}" ${sel}>${d.name}</option>`;
                        });
                        $('#deptSelect').html(opts).prop('disabled', false);
                    });
            }

            function loadPositions(deptId, selectedPosId) {
                if(!deptId) return;
                fetch(`/api/v1/positions?department_id=${deptId}`)
                    .then(res => res.json())
                    .then(res => {
                        let opts = '<option value="">Pilih Jabatan</option>';
                        res.data.forEach(p => {
                            const sel = p._id === selectedPosId ? 'selected' : '';
                            opts += `<option value="${p._id}" ${sel}>${p.name} (Lv. ${p.level})</option>`;
                        });
                        $('#posSelect').html(opts).prop('disabled', false);
                    });
            }

            // Init on load
            const initialBranch = $('#branchSelect').val();
            if(initialBranch) {
                loadDepartments(initialBranch, currentDeptId);
                if(currentDeptId) {
                    loadPositions(currentDeptId, currentPosId);
                }
            }

            $('#branchSelect').on('change', function() {
                $('#deptSelect').html('<option value="">Memuat...</option>').prop('disabled', true);
                $('#posSelect').html('<option value="">Pilih Departemen Dulu</option>').prop('disabled', true);
                loadDepartments($(this).val(), null);
            });

            $('#deptSelect').on('change', function() {
                $('#posSelect').html('<option value="">Memuat...</option>').prop('disabled', true);
                loadPositions($(this).val(), null);
            });

            $('#formEditEmployee').on('submit', function(e) {
                e.preventDefault();
                
                // HTML5 Validation check
                if (!this.checkValidity()) {
                    e.stopPropagation();
                    $(this).addClass('was-validated');
                    Swal.fire('Incomplete Form', 'Harap isi semua field yang wajib (*).', 'warning');
                    return;
                }
                
                const btn = $('#btnSubmit');
                btn.prop('disabled', true).html('<i class="spinner-border spinner-border-sm me-1"></i> Menyimpan...');

                const fd = new FormData(this);
                
                const payload = {
                    branch_id: fd.get('branch_id'),
                    department_id: fd.get('department_id'),
                    position_id: fd.get('position_id'),
                    status: fd.get('status'),
                    payment_cycle: fd.get('payment_cycle'),
                    join_date: fd.get('join_date'),
                    
                    full_name: fd.get('full_name'),
                    gender: fd.get('gender'),
                    birth_place: fd.get('birth_place'),
                    birth_date: fd.get('birth_date'),
                    religion: fd.get('religion'),
                    marital_status: fd.get('marital_status'),
                    blood_type: fd.get('blood_type'),
                    address: fd.get('address'),
                    city: fd.get('city'),
                    province: fd.get('province'),
                    postal_code: fd.get('postal_code'),
                    phone: fd.get('phone'),
                    email: fd.get('email'),

                    emergency_contact: {
                        name: fd.get('emergency_contact.name'),
                        relationship: fd.get('emergency_contact.relationship'),
                        phone: fd.get('emergency_contact.phone')
                    },

                    bank_account: {
                        bank_name: fd.get('bank_account.bank_name'),
                        account_number: fd.get('bank_account.account_number'),
                        account_holder_name: fd.get('bank_account.account_holder_name')
                    }
                };

                fetch(`/api/v1/employees/<%= employee._id %>`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                .then(res => res.json())
                .then(res => {
                    btn.prop('disabled', false).html('<i class="ti ti-device-floppy me-1"></i> Simpan Perubahan');
                    if(res.success) {
                        Swal.fire({
                            title: 'Berhasil!',
                            text: 'Data karyawan berhasil diperbarui.',
                            icon: 'success',
                            confirmButtonText: 'Kembali ke Daftar'
                        }).then(() => {
                            window.location.href = '/karyawan';
                        });
                    } else {
                        let errStr = res.message;
                        if(res.errors && res.errors.length > 0) {
                            errStr += '<br><small class="text-danger">' + res.errors.map(e => e.message).join('<br>') + '</small>';
                        }
                        Swal.fire('Gagal Menyimpan', errStr, 'error');
                    }
                })
                .catch(err => {
                    btn.prop('disabled', false).html('<i class="ti ti-device-floppy me-1"></i> Simpan Perubahan');
                    Swal.fire('Error', 'Terjadi kesalahan jaringan/sistem', 'error');
                });
            });
        });
    </script>
</body>
</html>
